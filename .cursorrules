### API calls — patrón estándar
```jsx
const [data, setData] = useState(null)
const [loading, setLoading] = useState(true)
const [error, setError] = useState(null)

useEffect(() => {
    api.get('/endpoint')
        .then(r => setData(r.data))
        .catch(e => setError(e.response?.data?.detail || 'Error'))
        .finally(() => setLoading(false))
}, [])
```

### Patrón polling — para pantallas en tiempo real
```jsx
// Usar este patrón para Venta Live, KDS, y cualquier pantalla live
useEffect(() => {
  const fetchData = async () => {
    try {
      const res = await api.get('/endpoint')
      setData(res.data)
      setLastUpdate(new Date())
    } catch (e) {
      // no resetear datos en error de polling — mantener últimos datos
      console.error('Polling error:', e)
    }
  }
  fetchData() // carga inmediata al montar
  const interval = setInterval(fetchData, 30000) // cada 30s
  return () => clearInterval(interval) // cleanup
}, [])
// Mostrar siempre: "Actualizado hace X segundos" con lastUpdate
```

