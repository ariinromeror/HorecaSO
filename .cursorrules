  { path:'/kds',        label:'Cocina KDS',   Icon:Bell,       roles:['admin','cocina','jefe_sala'] },
]
// Venta Live visible para admin, director y jefe_sala
// Icono Activity (pulso/actividad) de lucide-react
```

