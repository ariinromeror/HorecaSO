## SCHEMA DE BASE DE DATOS

```sql
-- CORE
tenants: id, nombre, nif, direccion, telefono, email, plan, activo, created_at
outlets: id, tenant_id, nombre, direccion, num_mesas, capacidad_total, created_at
usuarios: id, tenant_id, outlet_id, nombre, email, password_hash, rol, pin, activo, created_at

-- SALA
mesas: id, outlet_id, numero, capacidad, estado, posicion_x, posicion_y, zona, forma

-- CARTA
categorias_menu: id, tenant_id, nombre, icono, color, orden, activo
alergenos: id, nombre, icono
productos: id, tenant_id, categoria_id, nombre, descripcion, precio, precio_coste,
           iva_porcentaje, tiene_receta, activo, imagen_url, es_bebida,
           tiempo_preparacion
producto_alergenos: producto_id, alergeno_id

-- TPV
tickets: id, outlet_id, mesa_id, camarero_id, estado, total, total_iva,
         descuento_porcentaje, metodo_pago, num_comensales, notas,
         created_at, cobrado_at, tiempo_ocupacion
ticket_lineas: id, ticket_id, producto_id, cantidad, precio_unitario, subtotal,
               nota, enviado_cocina, enviado_cocina_at, estado_cocina
ticket_pagos: id, ticket_id, importe, metodo_pago, created_at
              -- Division de cuenta: multiples pagos por ticket
              -- ticket cobrado cuando suma(importe) >= tickets.total
cierres_caja: id, outlet_id, usuario_id, fecha, total_efectivo, total_tarjeta,
              total_bizum, total_transferencia, total_invitaciones,
              total_ventas, num_tickets, ticket_medio, created_at

-- VERIFACTU
verifactu_registros: id, tenant_id, ticket_id, numero_serie, fecha_expedicion,
                     fecha_hora_generacion, tipo_factura, base_imponible,
                     cuota_iva, importe_total, huella_anterior, huella_actual,
                     enviado_aeat, created_at

-- INVENTARIO
articulos: id, tenant_id, nombre, sku, unidad_medida, stock_actual, stock_minimo,
           stock_maximo, coste_unitario, categoria_almacen, created_at
lotes_inventario: id, articulo_id, outlet_id, cantidad, coste_unitario,
                  fecha_caducidad, numero_lote, created_at
movimientos_stock: id, articulo_id, outlet_id, tipo, cantidad, coste_unitario,
                   motivo, usuario_id, ticket_id, created_at
mermas: id, outlet_id, articulo_id, cantidad, motivo, coste_imputado,
        usuario_id, created_at
registros_appcc: id, outlet_id, usuario_id, tipo_control, nombre_equipo,
                 temperatura, conforme, observaciones, created_at

-- RECETAS
recetas: id, producto_id, rendimiento, tiempo_preparacion, instrucciones,
         coste_calculado, margen_porcentaje, semaforo, updated_at
receta_ingredientes: id, receta_id, articulo_id, cantidad_neta,
                     porcentaje_merma, unidad, orden

-- PROVEEDORES
proveedores: id, tenant_id, nombre, nif, email, telefono, direccion,
             condiciones_pago, dias_entrega, activo
pedidos_proveedor: id, tenant_id, proveedor_id, outlet_id, estado,
                   fecha_pedido, fecha_entrega_estimada, total_estimado
facturas_proveedor: id, tenant_id, proveedor_id, pedido_id, numero_factura,
                    fecha, fecha_vencimiento, total, pagada, procesada_ia,
                    imagen_url, created_at
facturas_proveedor_lineas: id, factura_id, articulo_id, cantidad,
                           coste_unitario, subtotal

-- RRHH
empleados: id, tenant_id, usuario_id, dni, nss, cargo, contrato,
           jornada_horas, salario_bruto_mensual, irpf_porcentaje,
           fecha_inicio, iban, activo
turnos: id, empleado_id, outlet_id, fecha, hora_inicio_planificada,
        hora_fin_planificada, hora_entrada, hora_salida,
        horas_trabajadas, horas_extra, tipo, incidencia
cuadrantes: id, outlet_id, semana_inicio, semana_fin, publicado, created_by
nominas: id, empleado_id, mes, anio, salario_bruto, total_devengos,
         ss_empleado, irpf, total_deducciones, liquido,
         ss_empresa, coste_total_empresa, pagada, created_at

-- CLIENTES Y RESERVAS
clientes: id, tenant_id, nombre, email, telefono, total_visitas,
          gasto_total, puntos_fidelidad, created_at
reservas: id, outlet_id, mesa_id, cliente_id, nombre_cliente, telefono,
          fecha, hora, num_personas, estado, origen, notas, created_at

-- ANALYTICS
rentabilidad_mesas: id, mesa_id, outlet_id, ticket_id, fecha,
                    num_comensales, tiempo_ocupacion_minutos,
                    ingreso_total, ingreso_por_hora
ingenieria_menu: id, producto_id, periodo_inicio, periodo_fin,
                 unidades_vendidas, margen_total, clasificacion
```

