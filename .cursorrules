## ESQUEMA DE BASE DE DATOS — TABLAS PRINCIPALES

```sql
-- Multi-tenant
tenants: id (UUID), nombre, nif, created_at
outlets: id, tenant_id, nombre, num_mesas

-- Usuarios
usuarios: id, tenant_id, outlet_id, nombre, email, password_hash, 
          rol, activo, created_at
-- Roles: director | jefe_sala | camarero | cocina | almacen | admin

-- Mesas
mesas: id, outlet_id, numero, capacidad, estado (libre/ocupada/reservada),
       posicion_x, posicion_y, zona (terraza/interior/barra)

-- Carta
categorias_menu: id, tenant_id, nombre, orden
productos: id, tenant_id, categoria_id, nombre, precio, tiene_receta, activo

-- TPV
tickets: id, outlet_id, mesa_id, camarero_id, estado (abierto/cobrado/anulado),
         total, metodo_pago (efectivo/tarjeta/bizum/invitacion), 
         created_at, cobrado_at
ticket_lineas: id, ticket_id, producto_id, cantidad, precio_unitario, subtotal, nota

-- Verifactu (INMUTABLE — solo INSERT, nunca UPDATE/DELETE)
verifactu_registros: id, tenant_id, ticket_id, numero_serie, fecha_expedicion,
                     tipo_factura, base_imponible, cuota_iva, importe_total,
                     huella_anterior, huella_actual, xml_generado,
                     enviado_aeat, created_at

-- Inventario
articulos: id, tenant_id, nombre, sku, unidad_medida, stock_actual,
           stock_minimo, coste_unitario
lotes_inventario: id, articulo_id, outlet_id, cantidad, coste_unitario,
                  fecha_caducidad, created_at

-- Recetas
recetas: id, producto_id, rendimiento, instrucciones
receta_ingredientes: id, receta_id, articulo_id, cantidad_neta,
                     porcentaje_merma, unidad
-- Formula merma: peso_bruto = cantidad_neta / (1 - porcentaje_merma/100)

-- Proveedores
proveedores: id, tenant_id, nombre, nif, email, telefono
facturas_proveedor: id, tenant_id, proveedor_id, numero_factura, fecha,
                    total, procesada_ia, imagen_url
facturas_proveedor_lineas: id, factura_id, articulo_id, cantidad,
                           coste_unitario, subtotal

-- RRHH
empleados: id, tenant_id, usuario_id, dni, cargo, salario_mensual,
           fecha_inicio, activo
turnos: id, empleado_id, outlet_id, fecha, hora_entrada, hora_salida,
        horas_trabajadas

-- Reservas
reservas: id, outlet_id, mesa_id, nombre_cliente, telefono, fecha, hora,
          num_personas, estado (confirmada/cancelada/sentada), notas
```

