k_actual = 1, stock_minimo = 5 WHERE id = 'c0000001-0000-4000-8000-000000000003';\nUPDATE articulos SET stock_actual = 20, stock_minimo = 4 WHERE id = 'c0000001-0000-4000-8000-000000000004';"}